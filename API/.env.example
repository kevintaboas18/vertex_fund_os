# Claves de API para el engine WBJ (NO subir el .env real — está en .gitignore).
# El engine lee este archivo (API/.env). La app web las lee desde vertex.env.

# SEC EDGAR: no usa key, pero la SEC EXIGE un User-Agent con tu contacto real.
EDGAR_USER_AGENT=Vertex Fund OS - Kevin Taboas kevintaboas02@gmail.com

# Financial Modeling Prep: pares, gaps de earnings, revisiones.
FMP_API_KEY=

# Anthropic (Claude): capa de "judge" — responde lo cualitativo (moat, catalizadores,
# concentración, thesis-killers, tier de TAM) que sube la cobertura de Business/Market/Risk.
# Sin esta key, esos slots quedan N/S por diseño (el resto del análisis funciona igual).
ANTHROPIC_API_KEY=
# Opcional: modelo del judge (default claude-opus-4-8; usa claude-haiku-4-5 para abaratar).
JUDGE_MODEL=

# Opcionales
FINNHUB_API_KEY=
FRED_API_KEY=
